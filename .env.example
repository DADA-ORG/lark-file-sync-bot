# ===== 飞书/Lark 自建应用凭证（开发者后台 -> 凭证与基础信息） =====
LARK_APP_ID=cli_xxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# 你们用的是 Lark Suite 国际版（域名 larksuite.com），不是国内飞书（feishu.cn），
# 所以 API 域名要用 open.larksuite.com，这里已经按默认值配好，一般不用改
LARK_API_BASE_URL=https://open.larksuite.com

# 事件订阅 -> 加密策略。如果开启了"加密"，把 Encrypt Key 填这里；没开启就留空
LARK_ENCRYPT_KEY=
# 事件订阅 -> Verification Token（旧版校验方式，新版建议用签名校验，这里两个都支持）
LARK_VERIFICATION_TOKEN=

# ===== 多维表格 Base 配置 =====
# 下面这三个已经填成你给的测试 Base（YMHDbUAw8a72hTsPVbNlXnvMgqh），
# 后面换成正式 Base 时把这三行改成正式的 app_token/table_id 即可
# Base 的 app_token（网址 base/ 后面那一串）
BASE_APP_TOKEN=YMHDbUAw8a72hTsPVbNlXnvMgqh
# 岗位信息表的 table_id
BASE_JOBS_TABLE_ID=tblHC9cZOUNUmC1D
# 同步日志表的 table_id（新建的空表，专门记录处理日志，用于去重和排查）
BASE_LOG_TABLE_ID=tblpSzHgMRccUrMI

# 岗位信息表里各字段的"字段名"（必须和 Base 里实际的列名完全一致，用于代码里按字段名读写）
# 下面已经按 Customize Field 面板里看到的实际列名改好：客户 / 项目名称 / Lark Link/Notes
# （链接类型字段，代码里的 extractDocToken 会自动从链接里解析出 document_id）。
# 测试表里没有"别名"这一列，BASE_FIELD_ALIAS 先留着默认值，反正没有这一列的话代码会按空值处理，不影响运行
BASE_FIELD_COMPANY=客户
BASE_FIELD_POSITION=项目名称
BASE_FIELD_ALIAS=别名关键词
BASE_FIELD_DOC_TOKEN=Lark Link/Notes

# 岗位文档里用来定位"群内更新记录"区块的锚点文字（需要在每个岗位文档模板里提前放一个这样的标题）
DOC_ANCHOR_BLOCK_TEXT=群内更新记录

# ===== LLM 抽取配置 =====
# anthropic 或 openai
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ===== 内部函数间调用密钥 =====
# api/lark-event.js 触发 api/process-message.js 时用这个值互相校验身份，
# 防止外部直接 POST /api/process-message 白嫖调用。随便填一串随机字符串即可，
# 比如用 `openssl rand -hex 16` 生成
INTERNAL_SECRET=

# 本地用 vercel dev 调试时，Vercel 不一定会注入 VERCEL_URL，用这个兜底
# （线上部署不需要填，Vercel 会自动提供 VERCEL_URL）
PUBLIC_URL=http://localhost:3000
